<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Agregar Pokémon</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-900 text-center p-6">
<section class="max-w-xl mx-auto">

    <h1 class="text-3xl font-bold text-indigo-600 mb-6">Agregar Pokémon</h1>

    <form action="/pokedex/new" method="POST" class="bg-gray-100 p-6 rounded-xl shadow-md space-y-4">

        <% const campos = ["nombre", "descripcion", "tipo", "imagen", "debilidades", "fortalezas"]; %>

        <% campos.forEach(c => { %>
            <div class="bg-gray-300 border border-gray-500 p-4 rounded-lg shadow-sm">
                <label class="block font-semibold mb-1"><%= c.charAt(0).toUpperCase() + c.slice(1) %></label>
                <input 
                    name="<%= c %>" 
                    class="w-full border p-2 rounded" 
                    type="text" 
                    required
                    minlength="2"
                >

            </div>
        <% }) %>

        <input class="bg-indigo-600 text-white borderpx-4 py-2 rounded cursor-pointer hover:bg-indigo-700 transition" type="submit" value="Guardar Pokémon">

    </form>

    <a href="/menu" class="block mt-10 text-indigo-600 underline text-lg">Volver al menú</a>

</section>
</body>
</html>