<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-900 text-center p-10">
<section class="max-w-md mx-auto">

    <h1 class="text-3xl font-bold text-indigo-500 mb-6">Iniciar Sesión</h1>

    <form action="/login" method="POST" class="bg-gray-100 p-6 rounded-xl shadow space-y-4">

        <div>
            <label class="block font-semibold mb-1">Usuario</label>
            <input type="text" name="usuario" required class="w-full p-2 rounded border">
        </div>

        <div>
            <label class="block font-semibold mb-1">Contraseña</label>
            <input type="password" name="password" required class="w-full p-2 rounded border">
        </div>

        <input 
            type="submit" 
            value="Entrar"
            class="bg-indigo-600 text-white px-4 py-2 rounded cursor-pointer hover:bg-indigo-700 transition"
        >
    </form>

</section>
</body>
</html>
